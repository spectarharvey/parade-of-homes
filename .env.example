# --- Database (Neon Postgres) ---
# Create a free project at https://neon.tech, then copy the *pooled* connection string.
# It looks like: postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL="postgresql://neondb_owner:npg_qfspGmBF1tO4@ep-icy-river-aokj8ox2.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# --- Auth ---
# Secret used to sign session JWTs. Generate one with: openssl rand -base64 32
AUTH_SECRET="generate-a-long-random-string"

# --- Seed admin account (used by `npm run db:seed`) ---
ADMIN_EMAIL="admin@mcbia.org"
ADMIN_PASSWORD="parade2025"

# --- Seed demo builder account (for the builder portal) ---
BUILDER_EMAIL="builder@heritagehomes.com"
BUILDER_PASSWORD="builder2025"

# --- Cloudinary (image uploads in the admin) ---
# From your Cloudinary dashboard. Either set the single CLOUDINARY_URL…
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
# …or the three individual variables instead:
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""